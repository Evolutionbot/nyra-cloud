# Nyra Cloud Platform Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Claude API Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_ENDPOINT=https://api.anthropic.com

# Database Configuration (Optional for MVP, defaults to in-memory)
DATABASE_URL=postgresql://user:password@localhost:5432/nyra
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=nyra
DATABASE_USER=postgres
DATABASE_PASSWORD=

# Memory Configuration
MEMORY_BACKEND=memory
VECTOR_DB_URL=http://localhost:8080
VECTOR_DB_ENABLED=false

# Feature Flags
ENABLE_PERSISTENCE=false
ENABLE_EMOTIONAL_STATE_TRACKING=true
ENABLE_MEMORY_CONSOLIDATION=true

# API Configuration
CORS_ORIGIN=*
MAX_CONTEXT_WINDOW=800
MEMORY_FRAGMENT_COUNT=5

# Logging
LOG_LEVEL=info
